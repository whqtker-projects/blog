---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const publishedPosts = allPosts.filter(
    (post) => !post.data.status || post.data.status === 'published'
  );

  return publishedPosts.map((post) => {
    const seriesPosts = publishedPosts
      .filter((p) => p.data.series === post.data.series)
      .sort((a, b) => a.data.order - b.data.order);
    const idx = seriesPosts.findIndex((p) => p.id === post.id);
    const prevPost = idx > 0 ? seriesPosts[idx - 1] : null;
    const nextPost = idx < seriesPosts.length - 1 ? seriesPosts[idx + 1] : null;
    return {
      params: { slug: post.id },
      props: {
        post,
        prev: prevPost ? { slug: prevPost.id, title: prevPost.data.title } : null,
        next: nextPost ? { slug: nextPost.id, title: nextPost.data.title } : null,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  series={post.data.series}
  order={post.data.order}
  prev={prev}
  next={next}
>
  <Content />
</PostLayout>
