---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import ExampleList from '../../components/ExampleList.astro';
import {
  visibleExamplesForCurrentBuild,
  visiblePostsForCurrentBuild,
} from '../../utils/post-visibility.js';
import { postsForSeries, prevNextPosts } from '../../utils/post-ordering.ts';
import {
  buildSeriesContext,
  buildSeriesHierarchy,
} from '../../utils/series-hierarchy';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const allExamples = await getCollection('examples');
  const allIndexes = await getCollection('series_indexes');
  const visiblePosts = visiblePostsForCurrentBuild(allPosts);
  const visibleExamples = visibleExamplesForCurrentBuild(allExamples);
  const { seriesBySlug } = buildSeriesHierarchy(allIndexes);

  return visiblePosts.map((post) => {
    const seriesIndex = seriesBySlug.get(post.data.series);
    if (!seriesIndex) {
      throw new Error(
        `Post '${post.id}' references missing series '${post.data.series}'.`
      );
    }

    const seriesPosts = postsForSeries(visiblePosts, post.data.series);
    const { prev: prevPost, next: nextPost } = prevNextPosts(seriesPosts, post.id);
    return {
      params: { slug: post.id },
      props: {
        post,
        seriesContext: buildSeriesContext(seriesIndex, seriesBySlug),
        examples: visibleExamples
          .filter((example) => example.data.post === post.id)
          .sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title)),
        prev: prevPost ? { slug: prevPost.id, title: prevPost.data.title } : null,
        next: nextPost ? { slug: nextPost.id, title: nextPost.data.title } : null,
      },
    };
  });
}

const { post, seriesContext, examples, prev, next } = Astro.props;
const { Content } = await render(post);
const exampleItems = examples.map((example) => ({
  title: example.data.title,
  href: `/posts/${post.id}/examples/${example.id.split('/').pop()}`,
}));
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  seriesContext={seriesContext}
  prev={prev}
  next={next}
>
  <Content />
  {exampleItems.length > 0 && (
    <section class="examples">
      <h2>예제</h2>
      <ExampleList items={exampleItems} />
    </section>
  )}
</PostLayout>

<style>
  .examples {
    margin-top: 3rem;
  }
</style>
