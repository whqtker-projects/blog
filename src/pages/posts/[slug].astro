---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { visiblePostsForCurrentBuild } from '../../utils/post-visibility.js';
import { postsForSeries, prevNextPosts } from '../../utils/post-ordering.ts';
import {
  buildSeriesHierarchy,
  requireParentIndex,
} from '../../utils/series-hierarchy';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const allIndexes = await getCollection('series_indexes');
  const visiblePosts = visiblePostsForCurrentBuild(allPosts);
  const { seriesBySlug } = buildSeriesHierarchy(allIndexes);

  return visiblePosts.map((post) => {
    const childIndex = seriesBySlug.get(post.data.series);
    if (!childIndex) {
      throw new Error(
        `Post '${post.id}' references missing child series '${post.data.series}'.`
      );
    }

    const parentIndex = requireParentIndex(childIndex, seriesBySlug);
    const seriesPosts = postsForSeries(visiblePosts, post.data.series);
    const { prev: prevPost, next: nextPost } = prevNextPosts(seriesPosts, post.id);
    return {
      params: { slug: post.id },
      props: {
        post,
        seriesContext: {
          parentSlug: parentIndex.data.series,
          parentTitle: parentIndex.data.title,
          childSlug: childIndex.data.series,
          childTitle: childIndex.data.title,
        },
        prev: prevPost ? { slug: prevPost.id, title: prevPost.data.title } : null,
        next: nextPost ? { slug: nextPost.id, title: nextPost.data.title } : null,
      },
    };
  });
}

const { post, seriesContext, prev, next } = Astro.props;
const { Content } = await render(post);
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  seriesContext={seriesContext}
  prev={prev}
  next={next}
>
  <Content />
</PostLayout>
