---
import { getCollection, render } from 'astro:content';
import ExampleLayout from '../../../../layouts/ExampleLayout.astro';
import { visibleExamplesForCurrentBuild, visiblePostsForCurrentBuild } from '../../../../utils/post-visibility.js';
import { buildSeriesContext, buildSeriesHierarchy } from '../../../../utils/series-hierarchy';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const allExamples = await getCollection('examples');
  const allIndexes = await getCollection('series_indexes');
  const visiblePosts = visiblePostsForCurrentBuild(allPosts);
  const visibleExamples = visibleExamplesForCurrentBuild(allExamples);
  const visiblePostsBySlug = new Map(visiblePosts.map((post) => [post.id, post]));
  const { seriesBySlug } = buildSeriesHierarchy(allIndexes);

  return visibleExamples.flatMap((example) => {
    const attachedPost = visiblePostsBySlug.get(example.data.post);
    if (!attachedPost) return [];

    const seriesIndex = seriesBySlug.get(attachedPost.data.series);
    if (!seriesIndex) {
      throw new Error(
        `Example '${example.id}' references post '${attachedPost.id}', but that post references missing series '${attachedPost.data.series}'.`
      );
    }

    return {
      params: {
        slug: attachedPost.id,
        example: example.id.split('/').pop(),
      },
      props: {
        example,
        post: attachedPost,
        seriesContext: buildSeriesContext(seriesIndex, seriesBySlug),
      },
    };
  });
}

const { example, post, seriesContext } = Astro.props;
const { Content } = await render(example);
---
<ExampleLayout
  title={example.data.title}
  description={example.data.description}
  seriesContext={seriesContext}
  post={{ slug: post.id, title: post.data.title }}
>
  <Content />
</ExampleLayout>
