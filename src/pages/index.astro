---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts');
// Home page lists only published posts (D-33)
const publishedPosts = allPosts
  .filter((post) => !post.data.status || post.data.status === 'published')
  .sort((a, b) => a.data.series.localeCompare(b.data.series) || a.data.order - b.data.order);
---
<BaseLayout title="Blog">
  <main>
    <h1>Posts</h1>
    <ul>
      {publishedPosts.map((post) => (
        <li>
          <a href={`/posts/${post.id}`}>{post.data.title}</a>
          <span> — {post.data.series} #{post.data.order}</span>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>
