---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SeriesList from '../components/SeriesList.astro';
import { buildSeriesHierarchy, parentSeriesPath } from '../utils/series-hierarchy';

const seriesIndexes = await getCollection('series_indexes');
const { parentIndexes } = buildSeriesHierarchy(seriesIndexes);
const items = parentIndexes.map((idx) => ({
  title: idx.data.title,
  href: parentSeriesPath(idx.data.series),
  description: idx.data.description,
}));
---
<BaseLayout title="Blog">
  <main>
    <h1>Series</h1>
    <SeriesList items={items} />
  </main>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }
</style>
