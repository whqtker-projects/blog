---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const seriesIndexes = await getCollection('series_indexes');
seriesIndexes.sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<BaseLayout title="Blog">
  <main>
    <h1>Series</h1>
    <ul>
      {seriesIndexes.map((idx) => (
        <li>
          <a href={`/series/${idx.data.series}`}>{idx.data.title}</a>
          {idx.data.description && <p class="description">{idx.data.description}</p>}
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    padding: 0.5rem 0;
    margin: 0 0 0.75rem;
  }

  li a {
    text-decoration: none;
    font-weight: 600;
  }

  li a:hover {
    text-decoration: underline;
    opacity: 1;
  }

  .description {
    font-size: 0.875rem;
    color: #666;
    margin: 0.2rem 0 0;
  }
</style>
