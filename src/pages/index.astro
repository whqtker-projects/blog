---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { seriesDisplayName } from '../utils/series';

const allPosts = await getCollection('posts');
const publishedPosts = allPosts
  .filter((post) => !post.data.status || post.data.status === 'published')
  .sort((a, b) => a.data.series.localeCompare(b.data.series) || a.data.order - b.data.order);

const seriesMap = new Map<string, typeof publishedPosts>();
for (const post of publishedPosts) {
  const s = post.data.series;
  if (!seriesMap.has(s)) seriesMap.set(s, []);
  seriesMap.get(s)!.push(post);
}
---
<BaseLayout title="Blog">
  <main>
    <h1>Posts</h1>
    {[...seriesMap.entries()].map(([series, posts]) => (
      <section>
        <h2><a href={`/series/${series}`}>{seriesDisplayName(series)}</a></h2>
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/posts/${post.id}`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  section {
    margin-bottom: 2.5rem;
  }

  h2 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  h2 a {
    text-decoration: none;
    font-weight: 600;
  }

  h2 a:hover {
    text-decoration: underline;
    opacity: 1;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    padding: 0.3rem 0;
    margin: 0;
  }

  li a {
    text-decoration: none;
  }

  li a:hover {
    text-decoration: underline;
    opacity: 1;
  }
</style>
