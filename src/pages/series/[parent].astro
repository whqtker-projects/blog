---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeriesList from '../../components/SeriesList.astro';
import { visiblePostsForCurrentBuild } from '../../utils/post-visibility.js';
import { postsForSeries } from '../../utils/post-ordering.ts';
import {
  buildSeriesHierarchy,
  childSeriesPath,
} from '../../utils/series-hierarchy';

export async function getStaticPaths() {
  const allIndexes = await getCollection('series_indexes');
  const allPosts = await getCollection('posts');
  const visiblePosts = visiblePostsForCurrentBuild(allPosts);
  const { parentIndexes, childrenByParent } = buildSeriesHierarchy(allIndexes);

  return parentIndexes.map((parentIndex) => {
    const childIndexes = childrenByParent.get(parentIndex.data.series) ?? [];

    return {
      params: { parent: parentIndex.data.series },
      props: {
        parentIndex,
        childIndexes,
        posts: childIndexes.length === 0 ? postsForSeries(visiblePosts, parentIndex.data.series) : [],
      },
    };
  });
}

const { parentIndex, childIndexes, posts } = Astro.props;
const items = childIndexes.map((childIndex) => ({
  title: childIndex.data.title,
  href: childSeriesPath(parentIndex.data.series, childIndex.data.series),
  description: childIndex.data.description,
}));
---
<BaseLayout title={parentIndex.data.title} description={parentIndex.data.description}>
  <main>
    <h1>{parentIndex.data.title}</h1>
    {parentIndex.data.description && (
      <p class="description">{parentIndex.data.description}</p>
    )}
    {items.length > 0 ? (
      <SeriesList items={items} />
    ) : (
      <ol>
        {posts.map((post) => (
          <li>
            <a href={`/posts/${post.id}`}>{post.data.title}</a>
          </li>
        ))}
      </ol>
    )}
  </main>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.75rem;
  }

  .description {
    font-size: 0.9rem;
    color: #555;
    margin: 0 0 1.75rem;
  }

  :global(.series-list .description) {
    font-size: 0.875rem;
    margin: 0.25rem 0 0;
  }

  ol {
    padding-left: 1.75rem;
    margin: 0;
  }

  li {
    padding: 0.4rem 0;
    margin: 0;
  }

  li a {
    text-decoration: none;
  }

  li a:hover {
    text-decoration: underline;
    opacity: 1;
  }
</style>
