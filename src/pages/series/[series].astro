---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allIndexes = await getCollection('series_indexes');
  const allPosts = await getCollection('posts');
  const publishedPosts = allPosts.filter(
    (post) => !post.data.status || post.data.status === 'published'
  );

  return allIndexes.map((idx) => ({
    params: { series: idx.data.series },
    props: {
      index: idx,
      posts: publishedPosts
        .filter((post) => post.data.series === idx.data.series)
        .sort((a, b) => a.data.order - b.data.order),
    },
  }));
}

const { index, posts } = Astro.props;
---
<BaseLayout title={index.data.title}>
  <main>
    <h1>{index.data.title}</h1>
    {index.data.description && <p class="description">{index.data.description}</p>}
    <ol>
      {posts.map((post) => (
        <li>
          <a href={`/posts/${post.id}`}>{post.data.title}</a>
        </li>
      ))}
    </ol>
  </main>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.75rem;
  }

  .description {
    font-size: 0.9rem;
    color: #555;
    margin: 0 0 1.75rem;
  }

  ol {
    padding-left: 1.75rem;
    margin: 0;
  }

  li {
    padding: 0.4rem 0;
    margin: 0;
  }

  li a {
    text-decoration: none;
  }

  li a:hover {
    text-decoration: underline;
    opacity: 1;
  }
</style>
