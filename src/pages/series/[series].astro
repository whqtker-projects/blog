---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { seriesDisplayName } from '../../utils/series';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const publishedPosts = allPosts.filter(
    (post) => !post.data.status || post.data.status === 'published'
  );

  const seriesSet = new Set(publishedPosts.map((post) => post.data.series));
  return [...seriesSet].map((series) => ({
    params: { series },
    props: {
      posts: publishedPosts
        .filter((post) => post.data.series === series)
        .sort((a, b) => a.data.order - b.data.order),
    },
  }));
}

const { series } = Astro.params;
const { posts } = Astro.props;
---
<BaseLayout title={seriesDisplayName(series!)}>
  <main>
    <h1>{seriesDisplayName(series!)}</h1>
    <ol>
      {posts.map((post) => (
        <li>
          <a href={`/posts/${post.id}`}>{post.data.title}</a>
        </li>
      ))}
    </ol>
  </main>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 1.5rem;
  }

  ol {
    padding-left: 1.75rem;
    margin: 0;
  }

  li {
    padding: 0.4rem 0;
    margin: 0;
  }

  li a {
    text-decoration: none;
  }

  li a:hover {
    text-decoration: underline;
    opacity: 1;
  }
</style>
