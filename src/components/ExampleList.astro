---
interface ExampleListItem {
  title: string;
  href: string;
}

interface Props {
  items: ExampleListItem[];
}

const { items } = Astro.props;
---
<ul class="example-list">
  {items.map((item) => (
    <li>
      <a href={item.href}>
        <span>{item.title}</span>
        <span class="icon" aria-hidden="true">↗</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .example-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .example-list li {
    padding: 0.75rem 0;
    border-top: 1px solid #e5e5e5;
  }

  .example-list li:last-child {
    border-bottom: 1px solid #e5e5e5;
  }

  .example-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    font-weight: 600;
  }

  .example-list a:hover {
    text-decoration: underline;
    opacity: 1;
  }

  .icon {
    font-size: 0.9em;
    line-height: 1;
  }
</style>
