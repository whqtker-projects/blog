---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/">Blog</a>
    </header>
    <slot />
  </body>
</html>

<style>
  .site-header a {
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
  }
</style>
