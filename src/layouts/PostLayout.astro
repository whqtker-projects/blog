---
import BaseLayout from './BaseLayout.astro';
interface NavLink {
  slug: string;
  title: string;
}

interface SeriesContext {
  parentSlug: string;
  parentTitle: string;
  childSlug: string;
  childTitle: string;
}

interface Props {
  title: string;
  description?: string;
  seriesContext: SeriesContext;
  prev?: NavLink | null;
  next?: NavLink | null;
}
const { title, description, seriesContext, prev, next } = Astro.props;
---
<BaseLayout title={title} description={description} ogType="article">
  <article>
    <header>
      <p class="breadcrumb">
        <a href={`/series/${seriesContext.parentSlug}`}>{seriesContext.parentTitle}</a>
        {' / '}
        <a href={`/series/${seriesContext.parentSlug}/${seriesContext.childSlug}`}>
          {seriesContext.childTitle}
        </a>
      </p>
      <h1>{title}</h1>
    </header>
    <slot />
    <nav class="post-nav">
      {prev && <a class="prev" href={`/posts/${prev.slug}`}>← {prev.title}</a>}
      {next && <a class="next" href={`/posts/${next.slug}`}>{next.title} →</a>}
    </nav>
  </article>
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.875rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .breadcrumb a {
    color: #666;
  }

  header h1 {
    margin-top: 0;
  }

  .post-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e5e5;
    font-size: 0.875rem;
  }

  .post-nav a {
    text-decoration: none;
    min-width: 0;
    overflow-wrap: break-word;
  }

  .post-nav a:hover {
    text-decoration: underline;
    opacity: 1;
  }

  .post-nav .next {
    margin-left: auto;
    text-align: right;
  }
</style>
