---
import BaseLayout from './BaseLayout.astro';
import BackToTopButton from '../components/BackToTopButton.astro';

interface SeriesContext {
  parentSlug: string;
  parentTitle: string;
  childSlug?: string | null;
  childTitle?: string | null;
}

interface PostLink {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description?: string;
  seriesContext: SeriesContext;
  post: PostLink;
}

const { title, description, seriesContext, post } = Astro.props;
---
<BaseLayout title={title} description={description} ogType="article">
  <article>
    <header>
      <p class="breadcrumb">
        <a href={`/series/${seriesContext.parentSlug}`}>{seriesContext.parentTitle}</a>
        {seriesContext.childSlug && seriesContext.childTitle && (
          <>
            {' / '}
            <a href={`/series/${seriesContext.parentSlug}/${seriesContext.childSlug}`}>
              {seriesContext.childTitle}
            </a>
          </>
        )}
        {' / '}
        <a href={`/posts/${post.slug}`}>{post.title}</a>
      </p>
      <h1>{title}</h1>
    </header>
    <slot />
  </article>
  <BackToTopButton />
</BaseLayout>

<style>
  .breadcrumb {
    font-size: 0.875rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .breadcrumb a {
    color: #666;
  }

  header h1 {
    margin-top: 0;
  }
</style>
